{
  "info": {
    "name": "Plateforme Investissement Backend - Simple",
    "description": "Collection Postman simplifiee pour tester le backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001"
    },
    {
      "key": "testEmail",
      "value": "investisseur.postman@example.com"
    },
    {
      "key": "testPassword",
      "value": "Password123"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "offeringId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('API disponible', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.status).to.eql('ok');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"firstName\": \"Postman\",\n  \"lastName\": \"Investor\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201 ou email deja utilise', function () {",
              "  pm.expect([201, 400]).to.include(pm.response.code);",
              "});",
              "",
              "const json = pm.response.json();",
              "if (pm.response.code === 201) {",
              "  pm.collectionVariables.set('token', json.token);",
              "  pm.test('Token cree', function () {",
              "    pm.expect(json.token).to.be.a('string').and.not.empty;",
              "  });",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Token recu et sauvegarde', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.token).to.be.a('string').and.not.empty;",
              "  pm.collectionVariables.set('token', json.token);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Me",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "me"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Profil retourne sans mot de passe', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.property('email');",
              "  pm.expect(json).to.not.have.property('password');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "List Offerings",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/offerings",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "offerings"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Liste des offres', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.be.an('array');",
              "  if (json.length > 0) {",
              "    pm.collectionVariables.set('offeringId', json[0].id);",
              "  }",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Offering By Id",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/offerings/{{offeringId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "offerings",
            "{{offeringId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Offre retournee', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.id).to.eql(pm.collectionVariables.get('offeringId'));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Update My Profile",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Postman\",\n  \"lastName\": \"Updated\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/me/profile",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "me",
            "profile"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Profil modifie', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.firstName).to.eql('Postman');",
              "  pm.expect(json.lastName).to.eql('Updated');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
