          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201 ou email deja utilise', () => {",
                  "  pm.expect([201, 400]).to.include(pm.response.code);",
                  "});",
                  "const json = pm.response.json();",
                  "if (pm.response.code === 201) {",
                  "  pm.test('Inscription retourne token et utilisateur', () => {",
                  "    pm.expect(json.token).to.be.a('string').and.not.empty;",
                  "    pm.expect(json.user).to.include.keys('id', 'email', 'firstName', 'lastName', 'role', 'kycStatus', 'balance');",
