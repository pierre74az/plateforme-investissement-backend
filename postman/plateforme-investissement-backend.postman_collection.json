                  "  });",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  pm.collectionVariables.set('userId', json.user.id);",
                  "} else {",
                  "  pm.test('Erreur email deja utilise', () => pm.expect(json.error).to.match(/deja|déjà|utilise|utilisé/i));",
                  "}"
                ]
              }
