generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  INVESTOR
  ADMIN
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        String       @id @default(cuid())
  email     String       @unique
  password  String
  firstName String
  lastName  String
  role      Role         @default(INVESTOR)
  balance   Float        @default(0)
  kycStatus KycStatus    @default(PENDING)
  createdAt DateTime     @default(now())
  kycDoc    KycDocument?
  subs      Subscription[]
}

model KycDocument {
  id         String    @id @default(cuid())
  userId     String    @unique
  user       User      @relation(fields: [userId], references: [id])
  idCardUrl  String
  addressUrl String
  status     KycStatus @default(PENDING)
  createdAt  DateTime  @default(now())
}

model Offering {
  id            String         @id @default(cuid())
  name          String
  sector        String
  pricePerShare Float
  totalShares   Int
  soldShares    Int            @default(0)
  minInvest     Float
  description   String
  riskLevel     String
  isOpen        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  subs          Subscription[]
}

model Subscription {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  offeringId  String
  offering    Offering @relation(fields: [offeringId], references: [id])
  shares      Int
  totalAmount    Float
  stripeSessionId String?  @unique
  createdAt   DateTime @default(now())
}